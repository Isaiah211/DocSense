# Base URL of the already-running local FastAPI backend.
# Leave blank to use the Vite dev proxy (recommended in development), which
# forwards /api/* to the target below.
VITE_API_BASE=http://localhost:8000

# Set to "true" to run the UI entirely against the in-memory mock server,
# without any backend or Ollama running. Useful for frontend-only iteration.
VITE_USE_MOCK=false

# Request timeout (ms) for the centralized API client.
VITE_API_TIMEOUT_MS=60000
